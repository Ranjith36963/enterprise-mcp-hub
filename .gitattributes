# Normalize line endings for cross-platform development.
# See https://git-scm.com/docs/gitattributes

* text=auto eol=lf

# Shell scripts must use LF even on Windows clones (bash chokes on CRLF).
*.sh      text eol=lf
*.bash    text eol=lf

# Batch / PowerShell scripts must use CRLF.
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf

# Python, JS, TS, Markdown, YAML — LF everywhere.
*.py      text eol=lf
*.pyi     text eol=lf
*.js      text eol=lf
*.jsx     text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.json    text eol=lf
*.toml    text eol=lf
*.sql     text eol=lf
*.html    text eol=lf
*.css     text eol=lf

# Declare binary types so git doesn't corrupt them.
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.pdf     binary
*.zip     binary
*.db      binary
*.sqlite  binary
